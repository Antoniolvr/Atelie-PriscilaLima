# ──────────────────────────────────────────────────
# Ateliê Priscila Lima — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no Git
# ──────────────────────────────────────────────────

# URL do seu site (sem barra no final)
# Exemplo: https://ateliepriscilalima.com.br
# Para múltiplos domínios, separe com vírgula:
# FRONTEND_URL=https://ateliepriscilalima.com.br,https://www.ateliepriscilalima.com.br
FRONTEND_URL=https://ateliepriscilalima.com.br

# Ambiente do PayPal: "sandbox" para testes, "live" para produção
PAYPAL_ENV=sandbox

# Credenciais do PayPal (acesse developer.paypal.com)
PAYPAL_CLIENT_ID=seu_client_id_aqui
PAYPAL_CLIENT_SECRET=seu_client_secret_aqui

# ID do Webhook PayPal (configure em developer.paypal.com > Webhooks)
# Deixe em branco para desabilitar verificação (não recomendado em produção)
PAYPAL_WEBHOOK_ID=seu_webhook_id_aqui

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente: "development" ou "production"
# Em production, ativa HSTS e outras proteções
NODE_ENV=production
