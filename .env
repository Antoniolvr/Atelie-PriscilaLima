# ──────────────────────────────────────────────────
# Ateliê Priscila Lima — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no Git
# ──────────────────────────────────────────────────

# URL do seu site (sem barra no final)
# Exemplo: https://ateliepriscilalima.com.br
# Para múltiplos domínios, separe com vírgula:
# FRONTEND_URL=https://ateliepriscilalima.com.br,https://www.ateliepriscilalima.com.br
FRONTEND_URL=https://ateliepriscilalima.com.br

FRONTEND_URL=https://atelie-priscilalima.onrender.com

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx


# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente: "development" ou "production"
# Em production, ativa HSTS e outras proteções
NODE_ENV=production
